# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# CryptoPay API Token (get from @CryptoBot -> My Apps -> Create App)
CRYPTO_PAY_TOKEN=your_cryptopay_token_here

# Telegram User ID of the admin (get from @userinfobot)
ADMIN_ID=123456789

# Telegram Channel ID where ads will be posted (e.g. -1001234567890)
CHANNEL_ID=-1001234567890

# Default price per 24 hours in USDT
DEFAULT_PRICE=1.0
